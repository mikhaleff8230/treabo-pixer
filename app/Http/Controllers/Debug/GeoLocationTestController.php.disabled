            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }
        .status.ok {
            background: #d1fae5;
            color: #065f46;
        }
        .status.error {
            background: #fee2e2;
            color: #991b1b;
        }
        .status.warning {
            background: #fef3c7;
            color: #92400e;
        }
        .details {
            background: #f9fafb;
            padding: 15px;
            border-radius: 4px;
            margin-top: 10px;
        }
        .details pre {
            margin: 0;
            font-size: 12px;
            overflow-x: auto;
        }
        .error-list, .warning-list {
            margin-top: 10px;
        }
        .error-list li {
            color: #dc2626;
            margin: 5px 0;
        }
        .warning-list li {
            color: #d97706;
            margin: 5px 0;
        }
        .timestamp {
            color: #6b7280;
            font-size: 14px;
        }
        .city-result {
            background: #e0f2fe;
            padding: 15px;
            border-radius: 4px;
            margin-top: 10px;
            border-left: 4px solid #0284c7;
        }
        .city-result h4 {
            margin: 0 0 10px 0;
            color: #0c4a6e;
        }
        .city-result p {
            margin: 5px 0;
            color: #075985;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>📍 Тест геолокации</h1>
        <div class="timestamp">Время проверки: ' . $results['timestamp'] . '</div>
    </div>

    <div class="summary ' . ($results['success'] ? 'success' : 'error') . '">
        <h2>' . ($results['success'] ? '✅ Все проверки пройдены' : '❌ Обнаружены ошибки') . '</h2>';
        
        $testIp = request()->query('ip', request()->ip());
        if (in_array($testIp, ['127.0.0.1', '::1'])) {
            $testIp = '95.24.18.3';
        }
        
        $html .= '<p>Тестовый IP: <strong>' . htmlspecialchars($testIp) . '</strong></p>';
        $html .= '<p>Ваш реальный IP: <strong>' . htmlspecialchars(request()->ip()) . '</strong></p>';
        
        $html .= '<p style="margin-top: 10px;">
            <a href="?clear_cache=1&ip=' . urlencode($testIp) . '" 
               style="background: #ef4444; color: white; padding: 8px 16px; border-radius: 4px; text-decoration: none; display: inline-block; margin-right: 10px;"
               onclick="return confirm(\'Очистить кэш для IP ' . htmlspecialchars($testIp) . '? Это позволит проверить работу DaData API.\')">
                🗑️ Очистить кэш для этого IP
            </a>
            <a href="?clear_cache=1&clear_all=1" 
               style="background: #dc2626; color: white; padding: 8px 16px; border-radius: 4px; text-decoration: none; display: inline-block;"
               onclick="return confirm(\'Очистить ВЕСЬ кэш геолокации (БД и Redis)? Это удалит все сохраненные IP адреса.\')">
                🗑️ Очистить ВЕСЬ кэш геолокации
            </a>
        </p>';
        
        if (session('success')) {
            $html .= '<p style="color: #10b981; margin-top: 10px;">✅ ' . htmlspecialchars(session('success')) . '</p>';
        }
        
        $html .= '</div>';

