            $html .= '<h3>Ошибки:</h3><ul class="error-list">';
            foreach ($results['errors'] as $error) {
                $html .= '<li>' . htmlspecialchars($error) . '</li>';
            }
            $html .= '</ul>';
        }

        if (!empty($results['warnings'])) {
            $html .= '<h3>Предупреждения:</h3><ul class="warning-list">';
            foreach ($results['warnings'] as $warning) {
                $html .= '<li>' . htmlspecialchars($warning) . '</li>';
            }
            $html .= '</ul>';
        }

        // Показываем результат определения города (приоритет DaData)
        $cityData = null;
        if (isset($results['checks']['dadata_test']['details']['city'])) {
            $cityData = $results['checks']['dadata_test']['details'];
        } elseif (isset($results['checks']['hybrid_system_test']['details']['city'])) {
            $cityData = $results['checks']['hybrid_system_test']['details'];
