    /**
     * Проверка маршрутов
     */
    private function checkRoutes()
    {
        $result = [
            'name' => 'Маршруты',
            'status' => 'ok',
            'details' => [],
            'errors' => [],
            'warnings' => [],
        ];

        try {
            $routesToCheck = [
                '/api/geoip/location' => 'GET,POST /api/geoip/location',
                '/api/geoip/cities/search' => 'GET /api/geoip/cities/search',
                '/api/geoip/city/save' => 'POST /api/geoip/city/save',
                '/api/geoip/city/saved' => 'GET /api/geoip/city/saved',
                '/api/geoip/addresses/search' => 'GET /api/geoip/addresses/search',
                '/api/geoip/address/save' => 'POST /api/geoip/address/save',
                '/api/geoip/address/saved' => 'GET /api/geoip/address/saved',
            ];

            $allRoutes = Route::getRoutes();
            
            foreach ($routesToCheck as $uri => $description) {
                $found = false;
                $routeInfo = null;
                
                // Ищем маршрут по URI
                foreach ($allRoutes as $route) {
                    $routeUri = '/' . $route->uri();
                    $checkUri = $uri;
                    
                    // Проверяем точное совпадение или совпадение без префикса api
                    if ($routeUri === $checkUri || 
                        $routeUri === str_replace('/api', '', $checkUri) ||
                        strpos($routeUri, str_replace('/api/geoip', '', $checkUri)) !== false) {
                        $found = true;
                        $routeInfo = [
                            'uri' => $route->uri(),
                            'methods' => $route->methods(),
                            'name' => $route->getName(),
                        ];
                        break;
                    }
                }
                
                if ($found && $routeInfo) {
                    $result['details'][$description] = [
                        'exists' => true,
                        'uri' => $routeInfo['uri'],
                        'methods' => $routeInfo['methods'],
                        'name' => $routeInfo['name'] ?: 'без имени',
                    ];
                } else {
                    $result['details'][$description] = [
                        'exists' => false,
                    ];
                    $result['warnings'][] = "Маршрут {$description} не найден";
                }
            }

        } catch (\Exception $e) {
            $result['status'] = 'error';
            $result['errors'][] = 'Ошибка при проверке маршрутов: ' . $e->getMessage();
        }

        return $result;
    }

    /**
     * Проверка таблицы geo_ip_cache (кэш БД)
     */
    private function checkDatabaseCache()
    {
        $result = [
            'name' => 'Кэш БД (geo_ip_cache)',
            'status' => 'ok',
            'details' => [],
            'errors' => [],
            'warnings' => [],
        ];

        try {
            // Проверяем существование таблицы
            $tableExists = Schema::hasTable('geo_ip_cache');
            $result['details']['table_exists'] = $tableExists;
            
            if (!$tableExists) {
                $result['status'] = 'error';
                $result['errors'][] = 'Таблица geo_ip_cache не существует. Выполните: php artisan migrate';
                return $result;
            }
            
            // Статистика по кэшу
            $totalRecords = GeoIpCache::count();
            $dadataRecords = GeoIpCache::where('source', 'dadata')->count();
            $maxmindRecords = GeoIpCache::where('source', 'maxmind')->count();
            $totalRequests = GeoIpCache::sum('request_count');
            
            $result['details']['statistics'] = [
                'total_records' => $totalRecords,
                'dadata_records' => $dadataRecords,
                'maxmind_records' => $maxmindRecords,
                'total_requests_saved' => $totalRequests,
                'estimated_dadata_quota_saved' => $dadataRecords > 0 ? $dadataRecords . ' запросов' : '0'
            ];
            
            // Топ IP по использованию
            $topIps = GeoIpCache::orderBy('request_count', 'desc')
                ->limit(5)
                ->get(['ip_address', 'city', 'country', 'request_count', 'last_used_at', 'source']);
            
            $result['details']['top_ips'] = $topIps->map(function ($item) {
                return [
                    'ip' => $item->ip_address,
                    'city' => $item->city,
                    'country' => $item->country,
                    'requests' => $item->request_count,
                    'last_used' => $item->last_used_at?->toDateTimeString(),
                    'source' => $item->source
                ];
            })->toArray();
            
            // Проверяем текущий IP
            $currentIp = request()->ip();
            if (!in_array($currentIp, ['127.0.0.1', '::1'])) {
                $currentIpCache = GeoIpCache::findByIp($currentIp);
                $result['details']['current_ip'] = [
                    'ip' => $currentIp,
                    'cached' => $currentIpCache !== null,
                    'city' => $currentIpCache?->city,
                    'source' => $currentIpCache?->source,
                    'request_count' => $currentIpCache?->request_count
                ];
            }

        } catch (\Exception $e) {
            $result['status'] = 'error';
            $result['errors'][] = 'Ошибка при проверке кэша БД: ' . $e->getMessage();
        }

        return $result;
    }

    /**
     * Проверка кэша Redis
     */
    private function checkCache()
    {
        $result = [
            'name' => 'Кэш Redis',
            'status' => 'ok',
            'details' => [],
            'errors' => [],
            'warnings' => [],
        ];

        try {
            $driver = config('cache.default');
            $result['details']['driver'] = $driver;
            
            $testKey = 'geolocation_test_' . time();
            $testValue = 'test_value_' . rand(1000, 9999);
            
            Cache::put($testKey, $testValue, 60);
            $retrieved = Cache::get($testKey);
            
            $result['details']['test_write_read'] = [
                'success' => $retrieved === $testValue,
                'value' => $retrieved,
            ];
            
            if ($retrieved !== $testValue) {
                $result['status'] = 'error';
                $result['errors'][] = 'Кэш не работает корректно';
            }
            
            Cache::forget($testKey);

        } catch (\Exception $e) {
            $result['status'] = 'error';
            $result['errors'][] = 'Ошибка при проверке кэша: ' . $e->getMessage();
        }

        return $result;
    }

    /**
     * Рендер HTML страницы
     */
    private function renderHtml($results)
    {
        $html = '<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Тест геолокации</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
