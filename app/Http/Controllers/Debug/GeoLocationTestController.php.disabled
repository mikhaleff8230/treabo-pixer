                    $html .= '<h4 style="color: #60a5fa; margin-top: 0;">📋 Логи выполнения:</h4>';
                    
                    // Добавляем инструкцию, если пользователь не авторизован
                    if (isset($check['details']['authenticated']) && !$check['details']['authenticated']) {
                        $html .= '<div style="background: #fef3c7; color: #92400e; padding: 10px; border-radius: 4px; margin-bottom: 10px; border-left: 4px solid #f59e0b;">';
                        $html .= '<strong>💡 Как получить токен для тестирования:</strong><br>';
                        $html .= '1. Авторизуйтесь на сайте через веб-интерфейс<br>';
                        $html .= '2. Откройте консоль браузера (F12)<br>';
                        $html .= '3. Выполните: <code style="background: #1e293b; padding: 2px 6px; border-radius: 3px;">document.cookie.match(/auth_token=([^;]+)/)?.[1]</code><br>';
                        $html .= '4. Скопируйте токен и добавьте в URL: <code style="background: #1e293b; padding: 2px 6px; border-radius: 3px;">?token=ВАШ_ТОКЕН</code><br>';
                        $html .= 'Или просто авторизуйтесь через веб-интерфейс перед открытием этой страницы.';
                        $html .= '</div>';
                    }
                    
                    foreach ($check['logs'] as $log) {
                        $html .= '<div style="padding: 2px 0; border-bottom: 1px solid rgba(255,255,255,0.1);">' . htmlspecialchars($log) . '</div>';
                    }
                    $html .= '</div>';
                }

                // Выводим детали
                if (!empty($check['details'])) {
                    $html .= '<div class="details" style="margin-top: 15px;">
                        <h4>📊 Детали:</h4>
                        <pre>' . htmlspecialchars(json_encode($check['details'], JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)) . '</pre>
                    </div>';
                }

                if (!empty($check['errors'])) {
                    $html .= '<ul class="error-list">';
                    foreach ($check['errors'] as $error) {
                        $html .= '<li>' . htmlspecialchars($error) . '</li>';
                    }
                    $html .= '</ul>';
                }

                if (!empty($check['warnings'])) {
                    $html .= '<ul class="warning-list">';
                    foreach ($check['warnings'] as $warning) {
                        $html .= '<li>' . htmlspecialchars($warning) . '</li>';
                    }
                    $html .= '</ul>';
                }

                $html .= '</div>';
            } else {
                // Обычная обработка для остальных проверок
                $html .= '<div class="check">
                    <div class="check-header">
                        <div class="check-title">' . htmlspecialchars($check['name']) . '</div>
                        <span class="status ' . $check['status'] . '">' . $check['status'] . '</span>
