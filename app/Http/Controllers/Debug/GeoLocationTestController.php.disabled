            $statusIcon = $addressSearch['status'] === 'ok' ? '✅' : ($addressSearch['status'] === 'warning' ? '⚠️' : '❌');
            
            $html .= '<div class="city-result" style="background: ' . ($statusClass === 'ok' ? '#d1fae5' : ($statusClass === 'warning' ? '#fef3c7' : '#fee2e2')) . '; border-left: 4px solid ' . ($statusClass === 'ok' ? '#10b981' : ($statusClass === 'warning' ? '#f59e0b' : '#ef4444')) . ';">
