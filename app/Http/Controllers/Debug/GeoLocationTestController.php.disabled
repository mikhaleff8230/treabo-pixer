                if (isset($addressSearch['details']['addresses']) && is_array($addressSearch['details']['addresses']) && count($addressSearch['details']['addresses']) > 0) {
                    $html .= '<div style="margin-top: 10px;"><strong>Примеры найденных адресов:</strong></div>';
                    foreach ($addressSearch['details']['addresses'] as $idx => $addr) {
